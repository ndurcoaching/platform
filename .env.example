# Copy this file to .env and fill in your own values.
# VITE_-prefixed variables are compiled into the public browser bundle —
# never put a secret in one. Everything else is read only by server-side
# code under api/ and must be set in Vercel's Environment Variables
# (Project Settings -> Environment Variables), not committed here.

# --- Frontend (safe to expose in the browser bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-side only (Vercel Edge Functions under api/) ---
SUPABASE_SERVICE_ROLE_KEY=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
SITE_URL=
